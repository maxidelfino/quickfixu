# Supabase Configuration
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# API Configuration
# For physical device testing: set your machine's local IP
# Windows: run `ipconfig` and find IPv4 Address
# Mac/Linux: run `ifconfig` and find inet address
# Example: EXPO_PUBLIC_API_URL=http://192.168.1.100:3000
# Leave empty to use emulator defaults (10.0.2.2 for Android, localhost for iOS)
EXPO_PUBLIC_API_URL=

# OAuth Configuration
# Google: use the matching client IDs for each platform. Backend must allow the same IDs.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Facebook OAuth
EXPO_PUBLIC_FACEBOOK_APP_ID=
