# QuickFixU Backend Environment Variables
# Copy this file to .env and fill in the actual values

# ============================================================
# DATABASE
# ============================================================
# PostgreSQL 15+ with PostGIS extension
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://quickfixu:password@localhost:5432/quickfixu_dev?schema=public"

# ============================================================
# JWT AUTHENTICATION
# ============================================================
# RSA 2048-bit keys (generate with: npm run generate-keys)
# Paths are relative to backend/ root
JWT_PRIVATE_KEY="keys/private.pem"
JWT_PUBLIC_KEY="keys/public.pem"

# ============================================================
# CLOUDINARY (Image Storage)
# ============================================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# ============================================================
# OAUTH - GOOGLE
# ============================================================
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Comma-separated allowlist of valid Google token audiences for backend verification.
# Include the web client plus any native Android/iOS client IDs used by mobile.
GOOGLE_CLIENT_IDS="your_web_client_id.apps.googleusercontent.com,your_android_client_id.apps.googleusercontent.com,your_ios_client_id.apps.googleusercontent.com"
# Optional single client ID fallback for older setups.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET="your_google_client_secret"

# ============================================================
# OAUTH - FACEBOOK
# ============================================================
# Get credentials from: https://developers.facebook.com/apps/
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

# ============================================================
# REDIS (Caching)
# ============================================================
# Local: redis://localhost:6379
# Cloud (e.g., Upstash): rediss://default:PASSWORD@HOST:PORT
REDIS_URL="redis://localhost:6379"

# ============================================================
# GEOCODING
# ============================================================
# Nominatim requires User-Agent header (free, no API key needed)
NOMINATIM_USER_AGENT="QuickFixU/1.0 (contact@quickfixu.com)"

# Google Geocoding API (fallback when Nominatim fails)
# Get key from: https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_GEOCODING_API_KEY="your_google_geocoding_api_key"

# ============================================================
# SERVER CONFIGURATION
# ============================================================
PORT=3000
NODE_ENV="development"
SEED_DEMO_USERS="false"

# CORS allowed origins (comma-separated for multiple origins)
# Example: "http://localhost:3000,http://localhost:19006,exp://192.168.1.100:8081"
CORS_ORIGINS="http://localhost:3000"

# ============================================================
# RATE LIMITING
# ============================================================
# Rate limit window in milliseconds (default: 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per window per IP (default: 100)
RATE_LIMIT_MAX_REQUESTS=100

# ============================================================
# FILE UPLOAD LIMITS
# ============================================================
# Max file size in bytes (default: 5MB)
MAX_FILE_SIZE=5242880

# Allowed image MIME types (comma-separated)
ALLOWED_IMAGE_TYPES="image/jpeg,image/png,image/webp"

# Allowed document MIME types for certifications
ALLOWED_DOC_TYPES="application/pdf,image/jpeg,image/png"
